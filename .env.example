# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/my_columns

# BetterAuth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (email)
RESEND_API_KEY=

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=my-columns-documents

# Observability (optional)
LOG_LEVEL=info
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
